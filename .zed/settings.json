{
  "file_types": {
    "Django": ["**/templates/**/*.html"]
  },
  "languages": {
    "HTML": {
      "prettier": {
        "allowed": false
      }
    },
    "Django": {
      "formatter": {
        "external": {
          "command": "./.venv/bin/djlint",
          "arguments": ["-", "--reformat", "--profile=django"]
        }
      },
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      }
    }
  }
}
